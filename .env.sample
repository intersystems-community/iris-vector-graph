# iris-vector-graph API configuration
# Copy to .env and fill in values. Never commit .env to source control.

# ── Authentication ────────────────────────────────────────────────────────────
# Set to a strong random string to enable API key authentication on all
# protected routes (/api/, /fhir-event/, /graphql). Leave empty to disable.
IVG_API_KEY=

# ── Access control ───────────────────────────────────────────────────────────
# Set to "true" to block Cypher mutation queries (CREATE/DELETE/MERGE/etc.)
# and fhir-event write requests. Useful for read-only analytics deployments.
IVG_READ_ONLY=false

# Set to "true" to allow fhir-event writes even when IVG_READ_ONLY=true.
IVG_ALLOW_FHIR_WRITES=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests.
# Leave empty for wildcard (credentials disabled). Set explicit origins to
# enable credentialed requests from browsers.
CORS_ORIGINS=

# ── IRIS connection ───────────────────────────────────────────────────────────
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER

# SECURITY: Change these in any non-development deployment.
# Using the default _SYSTEM/SYS credentials exposes IRIS as a superuser.
IRIS_USER=_SYSTEM
IRIS_PASSWORD=SYS
